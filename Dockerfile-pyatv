#docker buildx build --platform linux/amd64 -f Dockerfile-pyatv -t ghcr.io/mackid1993/ah4c-mackid1993:pyatv . --push

# See Dockerfile for the patch-overlay model (submodule + patches/).

FROM golang:alpine3.21 AS builder2

RUN mkdir -p /go/src/github.com/sullrich
WORKDIR /go/src/github.com/sullrich

RUN apk upgrade --no-cache && apk add --no-cache git patch

COPY upstream/ ./
COPY patches/ /tmp/patches/
COPY stall_tolerant_reader.go ./
RUN patch -p1 --no-fuzz --verbose < /tmp/patches/tune.patch \
    && grep -q 'WrapEncoderBody(resp.Body' main.go \
    && go build -o /opt/ah4c

# Copy upstream runtime assets from the submodule
COPY upstream/docker-start-pyatv.sh /opt/
COPY upstream/scripts/ /tmp/scripts/
COPY upstream/m3u/ /tmp/m3u/
COPY upstream/html/ /opt/html/
COPY upstream/static/ /opt/static/

FROM ghcr.io/postlund/pyatv:0.14.5 AS runner
LABEL maintainer="The Slayer <slayer@technologydragonslayer.com>"

RUN mkdir -p /opt/scripts /tmp/scripts /tmp/m3u /opt/html /opt/static
WORKDIR /opt

RUN apk upgrade --no-cache \
    && apk add --no-cache android-tools curl npm bash bind-tools ffmpeg procps nano tzdata tesseract-ocr

COPY --from=builder2 /opt /opt
COPY --from=builder2 /tmp /tmp

EXPOSE 7654
EXPOSE 8000

CMD ["./docker-start-pyatv.sh"]
